# The password for your secret orders page (yoursite.com/admin)
ADMIN_PASSWORD=ellieandgrace

# A long random string that keeps the admin login secure.
# Generate one by running:  openssl rand -hex 32
ADMIN_SECRET=replace-with-a-long-random-string

# Where orders are saved (a private Vercel Blob store). This is added
# automatically for you when the Blob store is connected to the project on
# Vercel — you do not need to fill it in by hand.
# BLOB_READ_WRITE_TOKEN=
